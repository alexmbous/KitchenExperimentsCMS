// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String  @id @default(cuid())
  name     String  @default("")
  email    String  @unique @default("")
  password String
  role     String? @default("editor")
}

model Recipe {
  id                  String           @id @default(cuid())
  title               String           @default("")
  slug                String           @unique @default("")
  summary             String           @default("")
  instructions        String           @default("")
  difficulty          String           @default("medium")
  prepTimeMinutes     Int?
  cookTimeMinutes     Int?
  status              String           @default("draft")
  featured            Boolean          @default(false)
  publishedAt         DateTime?
  heroImage_id        String?
  heroImage_filesize  Int?
  heroImage_width     Int?
  heroImage_height    Int?
  heroImage_extension String?
  ingredients         Ingredient[]     @relation("Ingredient_recipe")
  sessions            CookingSession[] @relation("CookingSession_recipe")
  tags                Tag[]            @relation("Recipe_tags")
  lessons             Lesson[]         @relation("Lesson_recipe")
  createdAt           DateTime?        @default(now())
}

model Ingredient {
  id       String  @id @default(cuid())
  name     String  @default("")
  amount   String  @default("")
  unit     String  @default("")
  optional Boolean @default(false)
  recipe   Recipe? @relation("Ingredient_recipe", fields: [recipeId], references: [id])
  recipeId String? @map("recipe")

  @@index([recipeId])
}

model CookingSession {
  id             String    @id @default(cuid())
  recipe         Recipe?   @relation("CookingSession_recipe", fields: [recipeId], references: [id])
  recipeId       String?   @map("recipe")
  cookedAt       DateTime?
  versionLabel   String    @default("")
  outcomeRating  Int?
  changesMade    String    @default("")
  resultNotes    String    @default("")
  wouldMakeAgain Boolean   @default(false)
  servingsMade   Int?

  @@index([recipeId])
}

model Tag {
  id      String   @id @default(cuid())
  name    String   @default("")
  color   String   @default("")
  recipes Recipe[] @relation("Recipe_tags")
}

model Lesson {
  id        String  @id @default(cuid())
  title     String  @default("")
  body      String  @default("")
  recipe    Recipe? @relation("Lesson_recipe", fields: [recipeId], references: [id])
  recipeId  String? @map("recipe")
  category  String  @default("")
  sortOrder Int?

  @@index([recipeId])
}
